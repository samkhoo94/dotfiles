#
exec --no-startup-id i3-msg 'workspace 1; exec /usr/bin/kitty'
exec --no-startup-id i3-msg 'workspace 3; exec /usr/bin/firefox'
# exec --no-startup-id obsidian
# exec --no-startup-id slack
exec --no-startup-id spotify
