{
    "Iceberg Create Table": {
    "prefix": "iceberg_create",
    "body": [
        "CREATE TABLE ${4:dev_}app.${1:[TABLE]} (",
        "    ${2:[COLUMN]} ${3:[DATATYPE]},",
        "    _sync_created_at timestamp(6)",
        "    _sync_updated_at timestamp(6)",
        ")",
        "LOCATION 's3://midnite-data-lakehouse${4:-dev}/raw/app/${1:[TABLE]}'",
        "TBLPROPERTIES ( 'table_type' = 'iceberg', 'format' = 'PARQUET', 'write_compression' = 'SNAPPY'"
    ],
    "description": "Create an Iceberg table."
    },
    "DBT Model Template": {
        "prefix": "dbtmodel",
        "body": [
            "{{",
            "    config(",
            "        unique_key='${1:[UNIQUE KEY]}',",
            "        indexes=[",
            "            {'columns':['${1:[UNIQUE KEY]}']}",
            "        ]",
            "    )",
            "}}",
            "",
            "with source_data as (",
            "    select        ",
            "        ${2:[COLUMNS]}",
            "    from {{ source('${3:stage}', '${4:[TABLE]}') }}",
            "    {% if is_incremental() %}",
            "       where last_updated >= {{ n_days_ago(3) }}",
            "    {% endif %}",
            ")",
            "",
            "select * from source_data",
            ""
        ]
    }
}
